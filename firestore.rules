rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;

      // Progress writes are server-owned. Callable Functions use the Admin SDK
      // and bypass rules; clients can only read their own synced state.
      match /pets/{petId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /eggs/{eggId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /checkins/{checkinId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /{document=**} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }

    match /pois/{poiId} {
      allow read: if true;
      allow write: if false;
    }

    match /petTemplates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    match /dialogueSets/{dialogueSetId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
